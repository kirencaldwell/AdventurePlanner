{
  "version": 2,
  "framework": "vite",
  "buildCommand": "cd adventure_planner && npm ci && npm run build",
  "outputDirectory": "adventure_planner/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    }
  ]
}
